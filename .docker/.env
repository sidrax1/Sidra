.docker.example

########################################################
# SIDRA Docker Environment Template
########################################################

NODE_ENV=production

PORT=3000

HOSTNAME=0.0.0.0

NEXT_TELEMETRY_DISABLED=1

########################################################
# Application
########################################################

NEXT_PUBLIC_APP_NAME=Sidra

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_ENV=development

########################################################
# Firebase
########################################################

NEXT_PUBLIC_FIREBASE_API_KEY=

NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=resora-bd7c5.firebaseapp.com

NEXT_PUBLIC_FIREBASE_PROJECT_ID=resora-bd7c5

NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=resora-bd7c5.firebasestorage.app

NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=495854321299

NEXT_PUBLIC_FIREBASE_APP_ID=

NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

########################################################
